generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------
// 1. Identity & Auth (NextAuth Standard)
// ---------------------------------------------------------

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  backgroundImage String?
  accounts      Account[]
  sessions      Session[]
  
  // App Relations
  notes         Note[]
  comments      Comment[]
  votes         Vote[]
  views         View[]
  folders       Folder[]
  bookmarks     Bookmark[]

  role          Role      @default(USER)

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

enum Role {
  USER
  ADMIN
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ---------------------------------------------------------
// 2. Core Content
// ---------------------------------------------------------

model Note {
  id          String   @id @default(cuid())
  title       String
  description String?
  isPublic    Boolean  @default(true)
  
  // Authorship
  authorId    String
  author      User     @relation(fields: [authorId], references: [id], onDelete: Cascade)

  // Versioning
  versions         NoteVersion[]
  currentVersionId String?       @map("current_version_id")
  // Note: We don't strictly relation currentVersion to NoteVersion here to avoid circular dependency issues during creation, 
  // but logically it points to a NoteVersion.id

  // Stats (Denormalized for performance, updated via transactions/events)
  viewCount   Int      @default(0)
  voteScore   Int      @default(0) // Upvotes - Downvotes

  // Relations
  comments    Comment[] // Global note-level comments (optional)
  views       View[]
  bookmarks   Bookmark[]

  folderId    String?
  folder      Folder?  @relation(fields: [folderId], references: [id], onDelete: SetNull)

  // Course Relation
  courseId    String?
  course      Course?  @relation(fields: [courseId], references: [id])
  
  // Metadata
  semester    String?  // e.g., "1-1", "1-2", "2-1"...

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([authorId])
  @@index([courseId])
  @@index([createdAt])
  @@index([folderId])
}

model Folder {
  id        String   @id @default(cuid())
  name      String
  
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  parentId  String?
  parent    Folder?  @relation("ParentChild", fields: [parentId], references: [id], onDelete: Cascade)
  children  Folder[] @relation("ParentChild")
  
  notes     Note[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, parentId, name]) // Unique folder names within the same parent/root
  @@index([userId])
  @@index([parentId])
}

model Course {
  id          String   @id @default(cuid())
  name        String   // e.g., "Linear Algebra"
  code        String   // e.g., "MA101"
  branch      String   // e.g., "CSE", "ECE", "MTH" (Group key)
  
  description String?
  
  notes       Note[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([code])     // Course codes should be unique
  @@index([branch])
}

model NoteVersion {
  id          String   @id @default(cuid())
  version     Int      // Incremental version number (1, 2, 3...)
  
  // File Storage
  s3Key       String   // The PDF file path in storage
  thumbnailKey String? // The thumbnail image path in storage

  // Relations
  noteId      String
  note        Note     @relation(fields: [noteId], references: [id], onDelete: Cascade)
  
  pages       Page[]

  createdAt   DateTime @default(now())

  @@unique([noteId, version]) // Ensure version numbers are unique per note
  @@index([noteId])
}

model Page {
  id            String   @id @default(cuid())
  number        Int      // Page number (1-indexed)
  
  // Parent
  versionId     String
  version       NoteVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)

  // Explicit Relations for Page-Level Interactivity
  votes         Vote[]
  comments      Comment[]

  @@unique([versionId, number]) // One record per page number per version
  @@index([versionId])
}

// ---------------------------------------------------------
// 3. Interactivity (Votes, Comments, Views)
// ---------------------------------------------------------

model Vote {
  id        String   @id @default(cuid())
  type      VoteType
  
  // Voter
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // Target: Vote is strictly on a PAGE (granular)
  pageId    String
  page      Page     @relation(fields: [pageId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, pageId]) // Prevent duplicate votes by same user on same page
  @@index([pageId])
  @@index([userId])
}

enum VoteType {
  UP
  DOWN
}

model Comment {
  id        String   @id @default(cuid())
  content   String
  isPrivate Boolean  @default(false) // Private = only visible to author (and maybe note owner)
  
  // Author
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // Targets (Polymorphic-ish, but explicit is better for Prisma)
  // Comments can be on a NOTE (general) or a PAGE (specific)
  noteId    String?
  note      Note?    @relation(fields: [noteId], references: [id], onDelete: Cascade)
  
  pageId    String?
  page      Page?    @relation(fields: [pageId], references: [id], onDelete: Cascade)
  
  // Threading
  parentId  String?
  parent    Comment?  @relation("ParentChild", fields: [parentId], references: [id], onDelete: Cascade)
  children  Comment[] @relation("ParentChild")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([noteId])
  @@index([pageId])
  @@index([userId])
}

model View {
  id        String   @id @default(cuid())
  
  // Viewer (Optional, for anonymous views tracking?)
  // Requirement doesn't specify anonymous, but usually views are tracked by IP or User.
  // We'll track authenticated users strictly for now.
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  noteId    String
  note      Note     @relation(fields: [noteId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([noteId])
}

model Bookmark {
  id         String   @id @default(cuid())
  
  // User who created the bookmark
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // Note being bookmarked
  noteId     String
  note       Note     @relation(fields: [noteId], references: [id], onDelete: Cascade)
  
  // Specific page number
  pageNumber Int
  
  // Optional label/note
  label      String?
  
  createdAt  DateTime @default(now())
  
  @@unique([userId, noteId, pageNumber]) // One bookmark per user per page
  @@index([userId])
  @@index([noteId])
}

