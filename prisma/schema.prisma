generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------
// 1. Identity & Auth (NextAuth Standard)
// ---------------------------------------------------------

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  backgroundImage String?
  accounts      Account[]
  sessions      Session[]
  
  // App Relations
  notes         Note[]
  comments      Comment[]
  votes         Vote[]
  views         View[]
  folders       Folder[]
  bookmarks     Bookmark[]
  annotations   Annotation[]

  role          Role      @default(USER)

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Social Relations
  sentRequests      FriendRequest[] @relation("SentRequests")
  receivedRequests  FriendRequest[] @relation("ReceivedRequests")
  
  groups            GroupMember[]
  createdGroups     Group[]         @relation("GroupCreator")
}

enum Role {
  USER
  ADMIN
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ---------------------------------------------------------
// 2. Core Content
// ---------------------------------------------------------

model Note {
  id          String   @id @default(cuid())
  title       String
  description String?
  // Authorship
  authorId    String
  author      User     @relation(fields: [authorId], references: [id], onDelete: Cascade)

  // Versioning
  versions         NoteVersion[]
  currentVersionId String?       @map("current_version_id")
  // Note: We don't strictly relation currentVersion to NoteVersion here to avoid circular dependency issues during creation, 
  // but logically it points to a NoteVersion.id

  // Stats (Denormalized for performance, updated via transactions/events)
  viewCount   Int      @default(0)
  voteScore   Int      @default(0) // Upvotes - Downvotes

  // Relations
  comments    Comment[] // Global note-level comments (optional)
  views       View[]
  bookmarks   Bookmark[]

  folderId      String?
  folder        Folder?   @relation(fields: [folderId], references: [id])
  
  courseId      String?
  course        Course?   @relation(fields: [courseId], references: [id])
  semester      String? // e.g., "1-1", "1-2", "2-1"...

  // Social & Media
  isPublic      Boolean   @default(true) // Legacy, use visibility
  visibility    NoteVisibility @default(PUBLIC)
  
  thumbnailS3Key String?

  sharedGroups   Group[]  @relation("SharedNotes")
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([authorId])
  @@index([courseId])
  @@index([createdAt])
  @@index([folderId])
}

model Folder {
  id        String   @id @default(cuid())

  name      String
  
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  parentId  String?
  parent    Folder?  @relation("ParentChild", fields: [parentId], references: [id], onDelete: Cascade)
  children  Folder[] @relation("ParentChild")
  
  notes     Note[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, parentId, name]) // Unique folder names within the same parent/root
  @@index([userId])
  @@index([parentId])
}

model Course {
  id          String   @id @default(cuid())
  name        String   // e.g., "Linear Algebra"
  code        String   // e.g., "MA101"
  branch      String   // e.g., "CSE", "ECE", "MTH" (Group key)
  
  description String?
  
  notes       Note[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([code])     // Course codes should be unique
  @@index([branch])
}

model NoteVersion {
  id          String   @id @default(cuid())
  version     Int      // Incremental version number (1, 2, 3...)
  
  // File Storage
  s3Key       String   // The PDF file path in storage
  thumbnailKey String? // The thumbnail image path in storage

  // Relations
  noteId      String
  note        Note     @relation(fields: [noteId], references: [id], onDelete: Cascade)
  
  pages       Page[]

  createdAt   DateTime @default(now())

  @@unique([noteId, version]) // Ensure version numbers are unique per note
  @@index([noteId])
}

model Page {
  id            String   @id @default(cuid())
  number        Int      // Page number (1-indexed)
  
  // Parent
  versionId     String
  version       NoteVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)

  // Explicit Relations for Page-Level Interactivity
  votes         Vote[]
  comments      Comment[]
  annotations   Annotation[]

  @@unique([versionId, number]) // One record per page number per version
  @@index([versionId])
}

// ---------------------------------------------------------
// 3. Interactivity (Votes, Comments, Views)
// ---------------------------------------------------------

model Vote {
  id        String   @id @default(cuid())
  type      VoteType
  
  // Voter
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // Target: Vote is strictly on a PAGE (granular)
  pageId    String
  page      Page     @relation(fields: [pageId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, pageId]) // Prevent duplicate votes by same user on same page
  @@index([pageId])
  @@index([userId])
}

enum VoteType {
  UP
  DOWN
}

model Comment {
  id        String   @id @default(cuid())
  content   String
  isPrivate Boolean  @default(false) // Private = only visible to author (and maybe note owner)
  
  // Author
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // Targets (Polymorphic-ish, but explicit is better for Prisma)
  // Comments can be on a NOTE (general) or a PAGE (specific)
  noteId    String?
  note      Note?    @relation(fields: [noteId], references: [id], onDelete: Cascade)
  
  pageId    String?
  page      Page?    @relation(fields: [pageId], references: [id], onDelete: Cascade)
  
  // Threading
  parentId  String?
  parent    Comment?  @relation("ParentChild", fields: [parentId], references: [id], onDelete: Cascade)
  children  Comment[] @relation("ParentChild")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([noteId])
  @@index([pageId])
  @@index([userId])
}

model View {
  id        String   @id @default(cuid())
  
  // Viewer (Optional, for anonymous views tracking?)
  // Requirement doesn't specify anonymous, but usually views are tracked by IP or User.
  // We'll track authenticated users strictly for now.
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  noteId    String
  note      Note     @relation(fields: [noteId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([noteId])
}

model Bookmark {
  id         String   @id @default(cuid())
  
  // User who created the bookmark
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // Note being bookmarked
  noteId     String
  note       Note     @relation(fields: [noteId], references: [id], onDelete: Cascade)
  
  // Specific page number
  pageNumber Int
  
  // Optional label/note
  label      String?
  
  createdAt  DateTime @default(now())
  
  @@unique([userId, noteId, pageNumber]) // One bookmark per user per page
  @@index([userId])
  @@index([noteId])
}


model Annotation {
  id        String   @id @default(cuid())
  
  // Content: Array of Stroke objects and TextNote objects
  // Stroke: { points: {x,y}[], color: string, type: 'pen'|'highlighter', width: number }
  // TextNote: { id: string, x: number, y: number, content: string, color: string, ... }
  // Points are stored in 0-1 coordinate space relative to page size
  content   Json     
  
  // Relations
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  pageId    String
  page      Page     @relation(fields: [pageId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, pageId]) // One annotation record per user per page
  @@index([pageId])
  @@index([userId])
}

// ---------------------------------------------------------
// 4. Social System
// ---------------------------------------------------------

model FriendRequest {
  id        String   @id @default(cuid())
  
  senderId  String
  sender    User     @relation("SentRequests", fields: [senderId], references: [id], onDelete: Cascade)
  
  receiverId String
  receiver   User     @relation("ReceivedRequests", fields: [receiverId], references: [id], onDelete: Cascade)
  
  status    RequestStatus @default(PENDING)
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([senderId, receiverId])
  @@index([receiverId])
  @@index([senderId])
}

enum RequestStatus {
  PENDING
  ACCEPTED
  REJECTED
}

model Group {
  id        String   @id @default(cuid())
  name      String
  image     String?  // Optional group icon
  
  creatorId String
  creator   User     @relation("GroupCreator", fields: [creatorId], references: [id], onDelete: Cascade)
  
  members   GroupMember[]
  sharedNotes Note[] @relation("SharedNotes")
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@index([creatorId])
}

model GroupMember {
  id        String   @id @default(cuid())
  
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  groupId   String
  group     Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  
  role      GroupRole @default(MEMBER)
  
  joinedAt  DateTime @default(now())

  @@unique([userId, groupId])
  @@index([groupId])
  @@index([userId])
}

enum GroupRole {
  ADMIN
  MEMBER
}

enum NoteVisibility {
  PUBLIC
  PRIVATE
  GROUP
}
